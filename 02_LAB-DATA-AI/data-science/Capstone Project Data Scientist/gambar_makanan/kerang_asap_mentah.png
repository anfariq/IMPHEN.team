-7V2S2S0-B6G0NX3-GD8NSSG.png",["Date","2026-04-18T09:15:23.526Z"],["Date","2026-04-18T09:15:23.526Z"],{"headingId":24,"headingEn":25,"subHeadingId":26,"subHeadingEn":27,"imageDesktopJpg":28,"imageMobileJpg":29,"isWithButton":30,"buttonTextId":31,"buttonTextEn":31,"buttonUrlDesktop":31,"buttonUrlMobile":31,"name":15,"createdAt":-1,"createdAtUtc":-1,"createdById":-1,"createdByUsername":13,"updatedAt":-1,"updatedAtUtc":-1,"updatedById":-1,"updatedByUsername":13},"Selamat Datang di Paxel Market Website","Welcome to Paxel Market Website","Temukan pengalaman belanja terbaik","Find the best shopping experience","https://s3-ap-southeast-1.amazonaws.com/paxelbucket/revamp/image-desktop-jpg-paxelmarket-microsite-4J10QMV-8K2XQ8U-0D2QQ1B-0G744M4.png","https://s3-ap-southeast-1.amazonaws.com/paxelbucket/revamp/image-mobile-jpg-paxelmarket-microsite-0RNDKL3-5O3RO8U-2D18OCD-FIBEBAF.png",false,"",[33,48],{"id":34,"content":35,"title":38,"imageJpg":41,"imageWebp":42,"status":43,"orderField":44,"isLastOrder":30,"createdAt":45,"createdAtDateOnly":46,"createdById":12,"createdByUsername":13,"updatedAt":47,"updatedAtDateOnly":-1,"updatedById":-1,"updatedByUsername":31},"69c3ff8e62a3c100013ef964",{"en":36,"id":37},"\u003Cp>PaxelMarket is a marketplace managed by Paxel, an app-based logistics company in Indonesia. Through PaxelMarket, anyone can easily shop for and sell a variety of local products, from regional snacks and trendy foods to healthy foods, beverages, and more.\u003C/p>\u003Cp>All of these products are made by MSMEs and retailers from across the archipelago, so in addition to shopping for your needs, you're also supporting the development of local businesses in Indonesia.\u003C/p>","\u003Cp>\u003Cstrong>PaxelMarket\u003C/strong>&nbsp;adalah marketplace yang dikelola oleh Paxel, perusahaan logistik berbasis aplikasi di Indonesia. Lewat PaxelMarket, siapa pun bisa dengan mudah berbelanja atau menjual berbagai produk lokal, mulai dari jajanan khas daerah, makanan kekinian, healthy food, minuman, dan lainnya\u003C/p>\u003Cp>Semua produk ini dibuat oleh pelaku UMKM dan peritel dari berbagai penjuru Nusantara, jadi selain belanja kebutuhan, kamu juga ikut mendukung perkembangan usaha lokal di tanah air.\u003C/p>",{"en":39,"id":40},"Platform for Taste Exploration","Platform untuk Eksplorasi Rasa","https://s3-ap-southeast-1.amazonaws.com/paxelbucket/revamp/image-jpg-paxelmarket-microsite-basic-service-4666GWB-TRLGJ6E-BET117A-4HMSCQX.png","https://s3-ap-southeast-1.amazonaws.com/paxelbucket/revamp/image-webp-paxelmarket-microsite-basic-service-IVAUE0G-5J3CQCU-G4PQXT6-MAUXRFR.webp","publish",1,["Date","2026-03-25T22:30:22.663Z"],["Date","2026-03-25T00:00:00.000Z"],["Date","0001-01-01T00:00:00.000Z"],{"id":49,"content":50,"title":53,"imageJpg":56,"imageWebp":57,"status":43,"orderField":58,"isLastOrder":30,"createdAt":59,"createdAtDateOnly":60,"createdById":12,"createdByUsername":13,"updatedAt":61,"updatedAtDateOnly":62,"updatedById":12,"updatedByUsername":13},"69c4006cca1bce0001f78e1c",{"en":51,"id":52},"\u003Cul>\u003Cli>Delivery service: \u003Cstrong>Sameday &amp; Nextday delivery\u003C/strong>\u003C/li>\u003Cli>Delivery slot time: \u003Cstrong>Every 2 hours (same as regular service)\u003C/strong>\u003C/li>\u003Cli>The application used by sellers as \u003Cstrong>merchants and buyers is the same\u003C/strong>\u003C/li>\u003Cli>Only sells food in the categories of \u003Cstrong>Frozen Food, Dry Food and Non-Perishable Food\u003C/strong>\u003C/li>\u003Cli>Payment method: \u003Cstrong>Bank Transfer (VA), Payment Gateway, QRIS and Paylater&nbsp;\u003C/strong>\u003C/li>\u003Cli>Coverage area: \u003Cstrong>all Paxel coverage except Paxel Agent\u003C/strong>\u003C/li>\u003C/ul>","\u003Cul>\u003Cli>Layanan pengiriman:&nbsp;\u003Cstrong>Sameday &amp; Nextday delivery\u003C/strong>\u003C/li>\u003Cli>Slot time pengiriman:&nbsp;\u003Cstrong>Per 2 jam (sama seperti regular service)\u003C/strong>\u003C/li>\u003Cli>Aplikasi yang digunakan seller sebagai&nbsp;\u003Cstrong>merchant dan buyer sama\u003C/strong>\u003C/li>\u003Cli>Hanya menjual makanan dengan kategori&nbsp;\u003Cstrong>Frozen Food, Dry Food dan Non-Perishable Food\u003C/strong>\u003C/li>\u003Cli>Metode pembayaran:&nbsp;\u003Cstrong>Bank Transfer (VA), Payment Gateway, QRIS dan Paylater\u003C/strong>\u003C/li>\u003Cli>Area coverage:&nbsp;\u003Cstrong>seluruh coverage Paxel kecuali Paxel Agen\u003C/strong>\u003C/li>\u003C/ul>",{"en":54,"id":55},"PaxelMarket is a food marketplace from Paxel that provides space for MSMEs to sell and expand their market reach online.","PaxelMarket merupakan marketplace makanan dari Paxel yang memberikan ruang bagi UMKM untuk berjualan dan memperluas jangkauan pasar mereka secara online.","https://s3-ap-southeast-1.amazonaws.com/paxelbucket/revamp/image-jpg-paxelmarket-microsite-basic-service-K8NWAQ1-IX1QPFY-3SUSMXU-3FP2CWL.png","https://s3-ap-southeast-1.amazonaws.com/paxelbucket/revamp/image-webp-paxelmarket-microsite-basic-service-2KIGEGE-W6CJIMS-BG15CK6-7X3AJJ2.webp",2,["Date","2026-03-25T22:34:04.548Z"],["Date","2026-03-25T00:00:00.000Z"],["Date","2026-03-25T23:20:15.484Z"],["Date","2026-03-25T00:00:00.000Z"],[64,76,88,101,114,127],{"id":65,"title":66,"description":69,"icon":72,"status":43,"orderField":44,"isLastOrder":30,"createdAt":73,"createdAtDateOnly":74,"createdById":12,"createdByUsername":13,"updatedAt":75,"updatedAtDateOnly":-1,"updatedById":-1,"updatedByUsername":31},"69c400c7ca1bce0001f78e1d",{"en":67,"id":68},"Store Registration Less Than 1 Minute","Registrasi Toko Kurang dari 1 Menit",{"en":70,"id":71},"The registration process is quite simple with easy terms and conditions.","Proses registrasi cukup dengan syarat dan ketentuan yang mudah.","https://s3-ap-southeast-1.amazonaws.com/paxelbucket/revamp/icon-paxelmarket-microsite-main-features-X8ITBMU-NXKPKVP-6BT1N0X-CP7SQVR.jpg",["Date","2026-03-25T22:35:35.683Z"],["Date","2026-03-25T00:00:00.000Z"],["Date","0001-01-01T00:00:00.000Z"],{"id":77,"title":78,"description":81,"icon":84,"status":43,"orderField":58,"isLastOrder":30,"createdAt":85,"createdAtDateOnly":86,"createdById":12,"createdByUsername":13,"updatedAt":87,"updatedAtDateOnly":-1,"updatedById":-1,"updatedByUsername":31},"69c400f562a3c100013ef965",{"en":79,"id":80},"Realtime Tracking","Pelacakan Realtime",{"en":82,"id":83},"Monitor shipments with live tracking with Sameday & Nextday service delivery SLA","Pantau kiriman dengan pelacakan secara langsung dengan SLA pengiriman Sameday & Nextday service","https://s3-ap-southeast-1.amazonaws.com/paxelbucket/revamp/icon-paxelmarket-microsite-main-features-3R257TH-1KQBTTK-YOU63LQ-X3YBVHO.jpg",["Date","2026-03-25T22:36:21.768Z"],["Date","2026-03-25T00:00:00.000Z"],["Date","0001-01-01T00:00:00.000Z"],{"id":89,"title":90,"description":93,"icon":96,"status":43,"orderField":97,"isLastOrder":30,"createdAt":98,"createdAtDateOnly":99,"createdById":12,"createdByUsername":13,"updatedAt":100,"updatedAtDateOnly":-1,"updatedById":-1,"updatedByUsername":31},"69c4011bc0a62a00011135cb",{"en":91,"id":92},"Various Categories","Berbagai Macam Kategori",{"en":94,"id":95},"Accepting and reliable in sending various types of frozen, non-frozen or dry food products","Menerima dan bisa diandalkan dalam mengirimkan berbagai jenis produk frozen, non-frozen atau dry food","https://s3-ap-southeast-1.amazonaws.com/paxelbucket/revamp/icon-paxelmarket-microsite-main-features-2VALK6X-WWPRDER-41K6MD0-I7YTHI0.jpg",3,["Date","2026-03-25T22:36:59.104Z"],["Date","2026-03-25T00:00:00.000Z"],["Date","0001-01-01T00:00:00.000Z"],{"id":102,"title":103,"description":106,"icon":109,"status":43,"orderField":110,"isLastOrder":30,"createdAt":111,"createdAtDateOnly":112,"createdById":12,"createdByUsername":13,"updatedAt":113,"updatedAtDateOnly":-1,"updatedById":-1,"updatedByUsername":31},"69c4014062a3c100013ef966",{"en":104,"id":105},"Affordable prices","Harga Terjangkau",{"en":107,"id":108},"Flexibility of package size up to maximum dimensions of 50x50x50 cm","Fleksibilitas ukuran paket sampai dengan dimensi maksimal 50x50x50 cm","https://s3-ap-southeast-1.amazonaws.com/paxelbucket/revamp/icon-paxelmarket-microsite-main-features-B6R541M-QU27HR3-A1IX0UM-AQJ5EBP.jpg",4,["Date","2026-03-25T22:37:36.742Z"],["Date","2026-03-25T00:00:00.000Z"],["Date","0001-01-01T00:00:00.000Z"],{"id":115,"title":116,"description":119,"icon":122,"status":43,"orderField":123,"isLastOrder":30,"createdAt":124,"createdAtDateOnly":125,"createdById":12,"createdByUsername":13,"updatedAt":126,"updatedAtDateOnly":-1,"updatedById":-1,"updatedByUsername":31},"69c4016cca1bce0001f78e1e",{"en":117,"id":118},"Flat Fee Commission","Commission Fee Flat",{"en":120,"id":121},"The registration process is simple, with simple terms and conditions. There's a 10% admin fee.","Proses registrasi cukup dengan syarat dan ketentuan yang mudah. Dengan admin fee sebesar 10%","https://s3-ap-southeast-1.amazonaws.com/paxelbucket/revamp/icon-paxelmarket-microsite-main-features-1NMIUOE-BI0EQF8-2X1412X-HQKC8BD.jpg",5,["Date","2026-03-25T22:38:20.472Z"],["Date","2026-03-25T00:00:00.000Z"],["Date","0001-01-01T00:00:00.000Z"],{"id":128,"title":129,"description":132,"icon":135,"status":43,"orderField":136,"isLastOrder":30,"createdAt":137,"createdAtDateOnly":138,"createdById":12,"createdByUsername":13,"updatedAt":139,"updatedAtDateOnly":-1,"updatedById":-1,"updatedByUsername":31},"69c4018cc0a62a00011135cc",{"en":130,"id":131},"Free Banner Ads","Gratis Banner Ads",{"en":133,"id":134},"Get banner ads that you can manage yourself according to your store's needs.","Dapatkan banner ads yang bisa anda kelola sendiri sesuai dengan kebutuhan toko anda","https://s3-ap-southeast-1.amazonaws.com/paxelbucket/revamp/icon-paxelmarket-microsite-main-features-06RCQ18-A0T7YHU-78I8633-QNPYKN2.jpg",6,["Date","2026-03-25T22:38:52.575Z"],["Date","2026-03-25T00:00:00.000Z"],["Date","0001-01-01T00:00:00.000Z"],[141,151,161,171,181],{"id":142,"title":143,"description":146,"image":147,"status":43,"orderField":44,"isLastOrder"