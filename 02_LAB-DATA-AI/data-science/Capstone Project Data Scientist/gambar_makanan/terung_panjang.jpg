<style>
#gamePopupOverlay{
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
background:rgba(0,0,0,0.35);
backdrop-filter:blur(8px);
display:flex;
justify-content:center;
align-items:center;
z-index:99999;
}

/* POPUP BOX */
#gamePopupBox{
position:relative;
width:420px;
border-radius:26px;
overflow:hidden;
background:linear-gradient(
135deg,
rgba(10,15,30,.92),
rgba(15,30,60,.95)
);
padding-top:85px;
box-shadow:
0 15px 50px rgba(0,0,0,.7),
0 0 35px rgba(61,169,252,.4);
animation:popupEnter .6s ease, floatBox 4s ease-in-out infinite;
cursor:pointer;
}

/* FLOAT EFFECT */
@keyframes floatBox{
0%{transform:translateY(0);}
50%{transform:translateY(-8px);}
100%{transform:translateY(0);}
}

/* APPEAR */
@keyframes popupEnter{
0%{transform:scale(.7);opacity:0;}
100%{transform:scale(1);opacity:1;}
}

/* LIGHT EFFECT (Idul Adha vibe soft glow) */
.light{
position:absolute;
top:-50%;
left:-50%;
width:200%;
height:200%;
background:radial-gradient(circle, rgba(61,169,252,.25), transparent 60%);
animation:rotateLight 10s linear infinite;
}

@keyframes rotateLight{
0%{transform:rotate(0deg);}
100%{transform:rotate(360deg);}
}

/* BORDER GLOW */
#gamePopupBox::before{
content:"";
position:absolute;
inset:-2px;
border-radius:28px;
background:linear-gradient(90deg,#3da9fc,#6bbcff,#3da9fc);
opacity:.7;
z-index:-1;
animation:glowMove 4s linear infinite;
}

@keyframes glowMove{
0%{filter:hue-rotate(0deg);}
100%{filter:hue-rotate(360deg);}
}

/* LOGO */
#gamePopupLogo{
position:absolute;
top:14px;
left:50%;
transform:translateX(-50%);
width:120px;
filter:drop-shadow(0 0 15px rgba(61,169,252,.7));
animation:logoFloat 3s ease-in-out infinite;
}

@keyframes logoFloat{
0%{transform:translateX(-50%) translateY(0);}
50%{transform:translateX(-50%) translateY(-10px);}
100%{transform:translateX(-50%) translateY(0);}
}

/* BANNER */
#gamePopupBanner{
width:100%;
display:block;
animation:bannerZoom 10s ease-in-out infinite;
}

@keyframes bannerZoom{
0%{transform:scale(1);}
50%{transform:scale(1.08);}
100%{transform:scale(1);}
}

/* TEXT */
#gamePopupText{
text-align:center;
padding:18px;
font-size:22px;
font-weight:800;
color:#6bbcff;
text-shadow:0 0 12px rgba(61,169,252,.7);
animation:textGlow 2s infinite alternate;
}

@keyframes textGlow{
from{text-shadow:0 0 5px #3da9fc;}
to{text-shadow:0 0 20px #6bbcff;}
}

/* CTA */
#popupCTA{
display:block;
width:80%;
margin:0 auto 20px auto;
text-align:center;
padding:14px;
border-radius:14px;
background:linear-gradient(90deg,#3da9fc,#6bbcff);
font-weight:bold;
font-size:17px;
color:#001220;
box-shadow:0 8px 25px rgba(61,169,252,.5);
animation:ctaPulse 1.5s infinite;
position:relative;
overflow:hidden;
}

/* SHINE EFFECT */
#popupCTA::after{
content:"";
position:absolute;
top:0;
left:-100%;
width:100%;
height:100%;
background:linear-gradient(120deg,transparent,rgba(255,255,255,.5),transparent);
animation:shine 3s infinite;
}

@keyframes shine{
100%{left:100%;}
}

@keyframes ctaPulse{
0%{transform:scale(1);}
50%{transform:scale(1.08);}
100%{transform:scale(1);}
}

/* PARTICLES */
.spark{
position:absolute;
bottom:0;
width:4px;
height:4px;
background:#6bbcff;
border-radius:50%;
opacity:.6;
animation:sparkMove 5s linear infinite;
}

@keyframes sparkMove{
0%{transform:translateY(0);}
100%{transform:translateY(-400px);opacity:0;}
}

/* MOBILE */
@media(max-width:600px){
#gamePopupBox{width:92%;}
#gamePopupLogo{width:90px;}
#gamePopupText{font-size:18px;}
#popupCTA{font-size:16px;padding:12px;}
}
</style>

